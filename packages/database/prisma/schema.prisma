// ─── Prisma Schema — Lendora ──────────────────────────────────────────────────
// Database: MySQL 8.0  (Railway in production / XAMPP in local dev)
// ORM:      Prisma 6
// 15 tables covering the full rental lifecycle

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider     = "mysql"
  url          = env("DATABASE_URL")
  directUrl    = env("DATABASE_DIRECT_URL")
  relationMode = "prisma"
}

// ─── Enums ────────────────────────────────────────────────────────────────────

enum UserRole {
  CUSTOMER
  VENDOR
  ADMIN
  SUPER_ADMIN
}

enum UserStatus {
  ACTIVE
  INACTIVE
  EMAIL_UNVERIFIED
  PHONE_UNVERIFIED
  SUSPENDED
  BANNED
  PENDING_VERIFICATION
}

enum VendorStatus {
  PENDING_VERIFICATION
  ACTIVE
  SUSPENDED
  BANNED
}

enum VerificationDocumentType {
  NATIONAL_ID
  PASSPORT
  DRIVING_LICENSE
}

enum ProductStatus {
  PENDING_REVIEW
  ACTIVE
  INACTIVE
  UNDER_MAINTENANCE
  REJECTED
  DELETED
}

enum ProductCondition {
  NEW
  LIKE_NEW
  GOOD
  FAIR
}

enum DeliveryOption {
  SELLER_DELIVERY
  CUSTOMER_PICKUP
  COURIER
}

enum ReturnMethod {
  SELLER_PICKUP
  COURIER_RETURN
  CUSTOMER_DROPOFF
}

enum RentalStatus {
  PENDING_CONFIRMATION
  CONFIRMED
  READY_FOR_PICKUP
  SHIPPED
  ACTIVE
  OVERDUE
  RETURN_INITIATED
  RETURN_IN_TRANSIT
  RETURN_RECEIVED
  DEPOSIT_PROCESSING
  COMPLETED
  CANCELLED
}

enum DepositStatus {
  HELD
  PARTIAL_REFUND_PENDING
  FULL_REFUND_PENDING
  PARTIALLY_REFUNDED
  FULLY_REFUNDED
  FORFEITED
}

enum ReturnCondition {
  EXCELLENT
  GOOD
  FAIR
  POOR
  DAMAGED
}

enum CancellationReason {
  VENDOR_UNAVAILABLE
  RENTER_REQUESTED
  PAYMENT_FAILED
  ITEM_DAMAGED
  ITEM_NOT_AS_DESCRIBED
  FRAUD_SUSPECTED
  ADMIN_ACTION
}

enum PaymentStatus {
  PENDING
  PROCESSING
  COMPLETED
  FAILED
  REFUNDED
  PARTIALLY_REFUNDED
  CANCELLED
}

enum PaymentMethod {
  BKASH
  NAGAD
  ROCKET
  CARD
  BANK
  CASH
}

enum PaymentType {
  RENTAL_PAYMENT
  DEPOSIT
  DEPOSIT_REFUND
  VENDOR_PAYOUT
  DAMAGE_DEDUCTION
  LATE_FEE_DEDUCTION
  PLATFORM_FEE
}

enum DisputeStatus {
  OPEN
  UNDER_REVIEW
  AWAITING_EVIDENCE
  RESOLVED_RENTER
  RESOLVED_VENDOR
  ESCALATED
  CLOSED
}

enum DisputeType {
  DAMAGE_CLAIM
  ITEM_NOT_RETURNED
  ITEM_NOT_AS_DESCRIBED
  DEPOSIT_DISPUTE
  PAYMENT_DISPUTE
  VENDOR_NO_SHOW
  OTHER
}

enum NotificationType {
  BOOKING_CONFIRMED
  BOOKING_CANCELLED
  RENTAL_STARTED
  RETURN_REQUESTED
  RETURN_CONFIRMED
  DEPOSIT_REFUNDED
  DEPOSIT_DEDUCTED
  NEW_REVIEW
  DISPUTE_OPENED
  DISPUTE_RESOLVED
  PAYMENT_RECEIVED
  PAYOUT_PROCESSED
  VENDOR_APPROVED
  VENDOR_SUSPENDED
  MESSAGE_RECEIVED
  ITEM_SHIPPED
  ITEM_DELIVERED
  LATE_FEE_WARNING
}

// ─── Table 1: users ───────────────────────────────────────────────────────────

model User {
  id               String     @id @default(cuid())
  email            String     @unique
  emailVerifiedAt  DateTime?
  phone            String?    @unique
  phoneVerifiedAt  DateTime?
  passwordHash     String
  name             String     @db.VarChar(80)
  address          String?    @db.VarChar(300)
  avatarUrl        String?    @db.VarChar(500)
  nidNumber        String?    @db.VarChar(30)
  nidFrontImageUrl String?    @db.VarChar(500)
  nidBackImageUrl  String?    @db.VarChar(500)
  bkashNumber      String?    @db.VarChar(15)
  role             UserRole   @default(CUSTOMER)
  status           UserStatus @default(EMAIL_UNVERIFIED)
  refreshTokenHash String?
  resetToken       String?    @unique
  resetTokenExpiry DateTime?
  emailVerifyToken String?    @unique
  lastLoginAt      DateTime?
  createdAt        DateTime   @default(now())
  updatedAt        DateTime   @updatedAt

  vendorProfile       VendorProfile?
  verificationDocs    VerificationDocument[]
  rentalsAsRenter     Rental[]               @relation("RenterRentals")
  paymentsAsPayer     Payment[]
  reviews             Review[]
  disputesRaised      Dispute[]              @relation("DisputeRaiser")
  disputesAgainst     Dispute[]              @relation("DisputeAgainst")
  wishlists           Wishlist[]
  notifications       Notification[]
  sentMessages        Message[]
  feedbackReceived    VendorFeedback[]   @relation("CustomerFeedback")

  @@index([email])
  @@index([phone])
  @@index([status])
  @@map("users")
}

// ─── Table 2: vendor_profiles ─────────────────────────────────────────────────

model VendorProfile {
  id                   String       @id @default(cuid())
  userId               String       @unique
  businessName         String       @db.VarChar(120)
  businessDescription  String?      @db.Text
  businessAddress      String?      @db.VarChar(300)
  district             String       @db.VarChar(60)
  division             String       @db.VarChar(60)
  bankAccountName      String?      @db.VarChar(120)
  bankAccountNumber    String?      @db.VarChar(20)
  bankName             String?      @db.VarChar(80)
  bkashNumber          String?      @db.VarChar(15)
  nagadNumber          String?      @db.VarChar(15)
  nidNumber            String?      @db.VarChar(30)
  nidFrontImageUrl     String?      @db.VarChar(500)
  nidBackImageUrl      String?      @db.VarChar(500)
  status               VendorStatus @default(PENDING_VERIFICATION)
  verifiedAt           DateTime?
  suspendedAt          DateTime?
  suspensionReason     String?      @db.VarChar(500)
  totalRentals         Int          @default(0)
  totalEarnings        Decimal      @default(0) @db.Decimal(12, 2)
  averageRating        Float        @default(0)
  responseTimeMinutes  Int?
  createdAt            DateTime     @default(now())
  updatedAt            DateTime     @updatedAt

  user             User             @relation(fields: [userId], references: [id], onDelete: Cascade)
  products         Product[]
  rentals          Rental[]         @relation("VendorRentals")
  payouts          VendorPayout[]
  feedbackGiven    VendorFeedback[]

  @@index([userId])
  @@index([status])
  @@index([district])
  @@map("vendor_profiles")
}

// ─── Table 3: verification_documents ─────────────────────────────────────────

model VerificationDocument {
  id               String                   @id @default(cuid())
  userId           String
  type             VerificationDocumentType
  documentNumber   String                   @db.VarChar(30)
  fileUrl          String                   @db.VarChar(500)
  verifiedAt       DateTime?
  rejectedAt       DateTime?
  rejectionReason  String?                  @db.VarChar(500)
  createdAt        DateTime                 @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@map("verification_documents")
}

// ─── Table 4: categories ──────────────────────────────────────────────────────

model Category {
  id           String    @id @default(cuid())
  name         String    @db.VarChar(60)
  slug         String    @unique @db.VarChar(80)
  emoji        String    @db.VarChar(10)
  description  String?   @db.Text
  parentId     String?
  sortOrder    Int       @default(0)
  isActive     Boolean   @default(true)
  createdAt    DateTime  @default(now())

  parent   Category?  @relation("CategoryTree", fields: [parentId], references: [id], onDelete: NoAction, onUpdate: NoAction)
  children Category[] @relation("CategoryTree")
  products Product[]

  @@index([slug])
  @@index([parentId])
  @@map("categories")
}

// ─── Table 5: products ────────────────────────────────────────────────────────

model Product {
  id                 String           @id @default(cuid())
  vendorId           String
  categoryId         String
  name               String           @db.VarChar(120)
  slug               String           @unique @db.VarChar(150)
  description        String           @db.Text
  pricePerDay        Decimal          @db.Decimal(10, 2)
  pricePerWeek       Decimal?         @db.Decimal(10, 2)
  pricePerMonth      Decimal?         @db.Decimal(10, 2)
  depositAmount      Decimal          @db.Decimal(10, 2)
  condition          ProductCondition @default(GOOD)
  status             ProductStatus    @default(ACTIVE)
  brand              String?          @db.VarChar(80)
  model              String?          @db.VarChar(80)
  district           String           @db.VarChar(60)
  division           String           @db.VarChar(60)
  address            String?          @db.VarChar(200)
  availableFrom      DateTime?
  availableUntil     DateTime?
  minRentalDays      Int              @default(1)
  maxRentalDays      Int?
  deliveryAvailable  Boolean          @default(false)
  deliveryFee        Decimal?         @db.Decimal(8, 2)
  deliveryOption     DeliveryOption   @default(CUSTOMER_PICKUP)
  deliveryOptions    Json             @default("[]")
  returnPickupFee    Decimal?         @db.Decimal(8, 2)
  specifications     Json?
  tags               Json             @default("[]")
  totalRentals       Int              @default(0)
  averageRating      Float            @default(0)
  reviewCount        Int              @default(0)
  quantity           Int              @default(1)
  isInstantBooking   Boolean          @default(false)
  deletedAt          DateTime?
  createdAt          DateTime         @default(now())
  updatedAt          DateTime         @updatedAt

  vendor   VendorProfile  @relation(fields: [vendorId], references: [id])
  category Category       @relation(fields: [categoryId], references: [id])
  media    ProductMedia[]
  rentals  Rental[]
  wishlists Wishlist[]
  reviews  Review[]
  blockedDates ProductBlockedDate[]

  @@index([vendorId])
  @@index([categoryId])
  @@index([status])
  @@index([district])
  @@index([division])
  @@index([pricePerDay])
  @@index([averageRating])
  @@index([createdAt])
  @@fulltext([name, description])
  @@map("products")
}

// ─── Table 6: product_media ───────────────────────────────────────────────────

model ProductMedia {
  id        String   @id @default(cuid())
  productId String
  url       String   @db.VarChar(500)
  altText   String?  @db.VarChar(200)
  sortOrder Int      @default(0)
  isPrimary Boolean  @default(false)
  createdAt DateTime @default(now())

  product Product @relation(fields: [productId], references: [id], onDelete: Cascade)

  @@index([productId])
  @@map("product_media")
}

// ─── Table 7: product_blocked_dates ──────────────────────────────────────────

model ProductBlockedDate {
  id        String   @id @default(cuid())
  productId String
  date      DateTime @db.Date
  reason    String?  @db.VarChar(120)

  product Product @relation(fields: [productId], references: [id], onDelete: Cascade)

  @@unique([productId, date])
  @@index([productId])
  @@map("product_blocked_dates")
}

// ─── Table 8: rentals (hub table) ─────────────────────────────────────────────

model Rental {
  id                  String              @id @default(cuid())
  productId           String
  renterId            String
  vendorId            String
  status              RentalStatus        @default(PENDING_CONFIRMATION)
  startDate           DateTime            @db.Date
  endDate             DateTime            @db.Date
  totalDays           Int
  pricePerDay         Decimal             @db.Decimal(10, 2)
  rentalFee           Decimal             @db.Decimal(12, 2)
  depositAmount       Decimal             @db.Decimal(10, 2)
  depositStatus       DepositStatus       @default(HELD)
  platformFeeRate     Decimal             @db.Decimal(4, 4) @default(0.1000)
  platformFee         Decimal             @db.Decimal(10, 2)
  vendorPayout        Decimal             @db.Decimal(12, 2)
  deliveryFee           Decimal             @db.Decimal(8, 2) @default(0)
  totalAmount           Decimal             @db.Decimal(12, 2)
  deliveryOption        DeliveryOption?
  selectedDelivery      DeliveryOption?
  courierForwardFee     Decimal?            @db.Decimal(8, 2)
  courierReturnFee      Decimal?            @db.Decimal(8, 2)
  deliveryAddress       String?             @db.VarChar(300)
  pickupAddress         String?             @db.VarChar(300)
  returnAddress         String?             @db.VarChar(300)
  renterNotes           String?             @db.VarChar(500)
  vendorNotes           String?             @db.VarChar(500)
  shipmentMethod        String?             @db.VarChar(60)
  trackingNumber        String?             @db.VarChar(100)
  estimatedDeliveryDate DateTime?
  shippedAt             DateTime?
  deliveredAt           DateTime?
  returnMethod          ReturnMethod?
  returnDate            DateTime?
  returnTrackingNumber  String?             @db.VarChar(100)
  lateDays              Int                 @default(0)
  lateFeeAmount         Decimal             @db.Decimal(10, 2) @default(0)
  overdueNotifiedAt     DateTime?
  confirmedAt           DateTime?
  startedAt             DateTime?
  returnInitiatedAt     DateTime?
  returnReceivedAt      DateTime?
  completedAt           DateTime?
  cancelledAt           DateTime?
  cancellationReason  CancellationReason?
  cancellationNote    String?             @db.VarChar(500)
  createdAt           DateTime            @default(now())
  updatedAt           DateTime            @updatedAt

  product     Product       @relation(fields: [productId], references: [id])
  renter      User          @relation("RenterRentals", fields: [renterId], references: [id])
  vendor      VendorProfile @relation("VendorRentals", fields: [vendorId], references: [id])
  payments       Payment[]
  returnRecord   ReturnRecord?
  review         Review?
  vendorFeedback VendorFeedback?
  dispute        Dispute?
  messages       Message[]
  lateFeeTransactions LateFeeTransaction[]

  @@index([productId])
  @@index([renterId])
  @@index([vendorId])
  @@index([status])
  @@index([startDate, endDate])
  @@index([createdAt])
  @@map("rentals")
}

// ─── Table 20: late_fee_transactions ─────────────────────────────────────────
// History of each automatic late-fee deduction applied to a rental's deposit.

model LateFeeTransaction {
  id               String   @id @default(cuid())
  rentalId         String
  lateDays         Int
  dailyRate        Decimal  @db.Decimal(10, 2)
  amount           Decimal  @db.Decimal(10, 2)
  totalLateFee     Decimal  @db.Decimal(10, 2)
  depositRemaining Decimal  @db.Decimal(10, 2)
  createdAt        DateTime @default(now())

  rental Rental @relation(fields: [rentalId], references: [id])

  @@index([rentalId])
  @@map("late_fee_transactions")
}

// ─── Table 9: return_records ──────────────────────────────────────────────────

model ReturnRecord {
  id                   String          @id @default(cuid())
  rentalId             String          @unique
  reportedByVendor     Boolean         @default(true)
  condition            ReturnCondition
  damageDescription    String?         @db.Text
  damageAmount         Decimal?        @db.Decimal(10, 2)
  depositDeduction     Decimal         @db.Decimal(10, 2) @default(0)
  depositRefund        Decimal         @db.Decimal(10, 2)
  lateDays             Int?
  latePenalty          Decimal?        @db.Decimal(10, 2)
  outstandingDue       Decimal?        @db.Decimal(10, 2)
  vendorAgreed         Boolean         @default(false)
  renterAgreed         Boolean         @default(false)
  adminReviewRequired  Boolean         @default(false)
  createdAt            DateTime        @default(now())
  updatedAt            DateTime        @updatedAt

  rental   Rental          @relation(fields: [rentalId], references: [id])
  evidence ReturnEvidence[]

  @@index([rentalId])
  @@map("return_records")
}

// ─── Table 10: return_evidence ────────────────────────────────────────────────

model ReturnEvidence {
  id             String   @id @default(cuid())
  returnRecordId String
  fileUrl        String   @db.VarChar(500)
  type           String   @db.VarChar(10)
  uploadedBy     String
  description    String?  @db.VarChar(300)
  uploadedAt     DateTime @default(now())

  returnRecord ReturnRecord @relation(fields: [returnRecordId], references: [id], onDelete: Cascade)

  @@index([returnRecordId])
  @@map("return_evidence")
}

// ─── Table 11: payments ───────────────────────────────────────────────────────

model Payment {
  id                    String        @id @default(cuid())
  rentalId              String
  payerId               String
  type                  PaymentType
  amount                Decimal       @db.Decimal(12, 2)
  currency              String        @db.VarChar(3) @default("BDT")
  method                PaymentMethod
  status                PaymentStatus @default(PENDING)
  externalReference     String?       @db.VarChar(100) @unique
  gatewayTransactionId  String?       @db.VarChar(200)
  gatewayResponse       Json?
  initiatedAt           DateTime      @default(now())
  completedAt           DateTime?
  failedAt              DateTime?
  failureReason         String?       @db.VarChar(300)
  createdAt             DateTime      @default(now())

  rental  Rental @relation(fields: [rentalId], references: [id])
  payer   User   @relation(fields: [payerId], references: [id])

  @@index([rentalId])
  @@index([payerId])
  @@index([status])
  @@index([externalReference])
  @@map("payments")
}

// ─── Table 12: vendor_payouts ─────────────────────────────────────────────────

model VendorPayout {
  id            String      @id @default(cuid())
  vendorId      String
  rentalId      String
  amount        Decimal     @db.Decimal(12, 2)
  method        PaymentMethod
  status        String      @db.VarChar(30) @default("PENDING")
  transactionRef String?    @db.VarChar(200)
  processedAt   DateTime?
  failureReason String?     @db.VarChar(300)
  createdAt     DateTime    @default(now())

  vendor VendorProfile @relation(fields: [vendorId], references: [id])

  @@index([vendorId])
  @@index([rentalId])
  @@index([status])
  @@map("vendor_payouts")
}

// ─── Table 13: reviews ────────────────────────────────────────────────────────

model Review {
  id              String   @id @default(cuid())
  rentalId        String   @unique
  reviewerId      String
  productId       String
  vendorId        String
  rating          Int
  title           String?  @db.VarChar(100)
  body            String   @db.Text
  vendorReply     String?  @db.Text
  vendorRepliedAt DateTime?
  helpfulCount    Int      @default(0)
  isVerified      Boolean  @default(true)
  createdAt       DateTime @default(now())

  rental   Rental  @relation(fields: [rentalId], references: [id])
  reviewer User    @relation(fields: [reviewerId], references: [id])
  product  Product @relation(fields: [productId], references: [id])

  @@index([productId])
  @@index([vendorId])
  @@index([reviewerId])
  @@index([rating])
  @@map("reviews")
}

// ─── Table 18: vendor_feedback ────────────────────────────────────────────────

model VendorFeedback {
  id         String   @id @default(cuid())
  rentalId   String   @unique
  vendorId   String
  customerId String
  rating     Int
  comment    String?  @db.Text
  createdAt  DateTime @default(now())

  rental   Rental        @relation(fields: [rentalId], references: [id])
  vendor   VendorProfile @relation(fields: [vendorId], references: [id])
  customer User          @relation("CustomerFeedback", fields: [customerId], references: [id])

  @@index([rentalId])
  @@index([customerId])
  @@index([vendorId])
  @@map("vendor_feedback")
}

// ─── Table 14: disputes ───────────────────────────────────────────────────────

model Dispute {
  id                String             @id @default(cuid())
  rentalId          String             @unique
  raisedById        String
  againstId         String
  type              DisputeType
  status            DisputeStatus      @default(OPEN)
  subject           String             @db.VarChar(120)
  description       String             @db.Text
  adminNotes        String?            @db.Text
  resolution        String?            @db.VarChar(50)
  resolutionNote    String?            @db.Text
  depositDeduction  Decimal?           @db.Decimal(10, 2)
  resolvedAt        DateTime?
  resolvedById      String?
  createdAt         DateTime           @default(now())
  updatedAt         DateTime           @updatedAt

  rental    Rental             @relation(fields: [rentalId], references: [id])
  raisedBy  User               @relation("DisputeRaiser", fields: [raisedById], references: [id])
  against   User               @relation("DisputeAgainst", fields: [againstId], references: [id])
  evidence  DisputeEvidence[]

  @@index([rentalId])
  @@index([raisedById])
  @@index([status])
  @@map("disputes")
}

model DisputeEvidence {
  id          String   @id @default(cuid())
  disputeId   String
  uploadedBy  String
  fileUrl     String   @db.VarChar(500)
  description String?  @db.VarChar(300)
  uploadedAt  DateTime @default(now())

  dispute Dispute @relation(fields: [disputeId], references: [id], onDelete: Cascade)

  @@index([disputeId])
  @@map("dispute_evidence")
}

// ─── Table 15: notifications ──────────────────────────────────────────────────

model Notification {
  id        String           @id @default(cuid())
  userId    String
  type      NotificationType
  title     String           @db.VarChar(120)
  body      String           @db.VarChar(500)
  data      Json?
  readAt    DateTime?
  createdAt DateTime         @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([readAt])
  @@index([createdAt])
  @@map("notifications")
}

// ─── Table 16: wishlists ──────────────────────────────────────────────────────

model Wishlist {
  userId    String
  productId String
  addedAt   DateTime @default(now())

  user    User    @relation(fields: [userId], references: [id], onDelete: Cascade)
  product Product @relation(fields: [productId], references: [id], onDelete: Cascade)

  @@id([userId, productId])
  @@index([userId])
  @@map("wishlists")
}

// ─── Table 19: system_settings ───────────────────────────────────────────────

model SystemSetting {
  key       String   @id @db.VarChar(100)
  value     String   @db.Text
  updatedAt DateTime @updatedAt

  @@map("system_settings")
}

// ─── Table 17: messages ───────────────────────────────────────────────────────

model Message {
  id            String   @id @default(cuid())
  rentalId      String
  senderId      String
  body          String   @db.Text
  attachmentUrl String?  @db.VarChar(500)
  readAt        DateTime?
  createdAt     DateTime @default(now())

  rental Rental @relation(fields: [rentalId], references: [id])
  sender User   @relation(fields: [senderId], references: [id])

  @@index([rentalId])
  @@index([senderId])
  @@map("messages")
}
