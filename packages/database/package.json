    "db:seed":     "tsx src/seed/index.ts",
    "db:studio":   "prisma studio"
  },
  "dependencies": {
    "@prisma/client": "^6.1.0"
  },
  "devDependencies": {
    "prisma":     "^6.1.0",
    "tsx":        "^4.19.2",
    "typescript": "^5.7.2",
    "@lendora/shared": "workspace:*"
  }
}
