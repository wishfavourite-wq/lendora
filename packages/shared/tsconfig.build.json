{
  "compilerOptions": {
    "target":           "ES2020",
    "module":           "ESNext",
    "moduleResolution": "bundler",
    "lib":              ["ES2020"],
    "strict":           true,
    "esModuleInterop":  true,
    "skipLibCheck":     true,
    "noEmit":           false,
    "outDir":           "./dist",
    "rootDir":          "./src",
    "declaration":      true,
    "declarationMap":   true,
    "sourceMap":        true
  },
  "include":  ["src/**/*.ts"],
  "exclude":  ["dist", "**/*.test.ts"]
}
