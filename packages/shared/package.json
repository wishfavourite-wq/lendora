{
  "name": "@lendora/shared",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".":            { "import": "./dist/index.js",      "types": "./dist/index.d.ts" },
    "./enums":     { "import": "./dist/enums/index.js", "types": "./dist/enums/index.d.ts" },
    "./types":     { "import": "./dist/types/index.js", "types": "./dist/types/index.d.ts" },
    "./schemas":   { "import": "./dist/schemas/index.js", "types": "./dist/schemas/index.d.ts" },
    "./constants": { "import": "./dist/constants/index.js", "types": "./dist/constants/index.d.ts" }
  },
  "scripts": {
    "build":      "tsc -p tsconfig.build.json",
    "type-check": "tsc --noEmit"
  },
  "dependencies": {
    "zod": "^3.24.1"
  },
  "devDependencies": {
    "typescript": "^5.7.2"
  }
}
