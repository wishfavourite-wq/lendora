{
  "$schema": "https://json.schemastore.org/tsconfig",
  "extends": "./base.json",
  "compilerOptions": {
    "target":           "ES2017",
    "lib":              ["dom", "dom.iterable", "ES2022"],
    "module":           "ESNext",
    "moduleResolution": "Bundler",
    "jsx":              "preserve",
    "noEmit":           true,
    "incremental":      true,
    "plugins":          [{ "name": "next" }],
    "allowJs":          true
  }
}
