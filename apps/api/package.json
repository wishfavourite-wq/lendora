{
  "name": "@lendora/api",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev":        "tsx watch src/main.ts",
    "build":      "tsc --project tsconfig.build.json || true",
    "start":      "node dist/main.js",
    "lint":       "eslint src --max-warnings 0",
    "typecheck":  "tsc --noEmit",
    "test":          "vitest run",
    "test:watch":    "vitest",
    "test:coverage": "vitest run --coverage"
  },
  "dependencies": {
    "@lendora/shared":           "workspace:*",
    "@lendora/database":         "workspace:*",
    "@prisma/client":            "^6.1.0",
    "express":                   "^4.21.2",
    "cors":                      "^2.8.5",
    "helmet":                    "^8.0.0",
    "cookie-parser":             "^1.4.7",
    "compression":               "^1.7.4",
    "express-rate-limit":        "^7.5.0",
    "jsonwebtoken":              "^9.0.2",
    "bcryptjs":                  "^2.4.3",
    "zod":                       "^3.24.1",
    "multer":                    "^1.4.5-lts.1",
    "sharp":                     "^0.33.5",
    "nodemailer":                "^6.9.16",
    "winston":                   "^3.17.0",
    "winston-daily-rotate-file": "^5.0.0",
    "uuid":                      "^11.0.3",
    "ms":                        "^2.1.3",
    "ioredis":                   "^5.4.1",
    "dotenv":                    "^16.4.7",
    "axios":                     "^1.7.9",
    "cloudinary":                "^2.5.1"
  },
  "devDependencies": {
    "@lendora/config":                   "workspace:*",
    "typescript":                        "^5.7.2",
    "@types/express":                    "^5.0.0",
    "@types/cors":                       "^2.8.17",
    "@types/cookie-parser":              "^1.4.8",
    "@types/compression":                "^1.7.5",
    "@types/jsonwebtoken":               "^9.0.7",
    "@types/bcryptjs":                   "^2.4.6",
    "@types/multer":                     "^1.4.12",
    "@types/nodemailer":                 "^6.4.17",
    "@types/uuid":                       "^10.0.0",
    "@types/ms":                         "^0.7.34",
    "tsx":                               "^4.19.2",
    "vitest":                            "^2.1.8",
    "@vitest/coverage-v8":               "^2.1.8",
    "vite-tsconfig-paths":               "^5.1.4",
    "supertest":                         "^7.0.0",
    "@types/supertest":                  "^6.0.2",
    "eslint":                            "^9.16.0",
    "@typescript-eslint/eslint-plugin":  "^8.18.1",
    "@typescript-eslint/parser":         "^8.18.1"
  }
}
