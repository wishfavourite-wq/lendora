# ─── App ──────────────────────────────────────────────────────────────────────
NODE_ENV=development
APP_NAME=Lendora
APP_URL=http://localhost:3000
API_URL=http://localhost:4000
API_PORT=4000

# Public URL of the API server — used by payment gateways for callback URLs.
# Must be reachable from the internet in production (or use ngrok in dev).
SERVER_URL=https://api.lendora.com.bd

# Public URL of the Next.js frontend — used in emails and payment redirects.
FRONTEND_URL=https://lendora.com.bd

# ─── Database ─────────────────────────────────────────────────────────────────
# Docker: mysql://lendora:<DB_PASSWORD>@mysql:3306/lendora
# XAMPP:  mysql://root:@localhost:3306/lendora
DATABASE_URL="mysql://root:@localhost:3306/lendora"
DATABASE_DIRECT_URL="mysql://root:@localhost:3306/lendora"

# Used by docker-compose to initialise the DB container
DB_ROOT_PASSWORD=rootpassword
DB_PASSWORD=lendorapass
DB_PORT=3306

# ─── Redis ────────────────────────────────────────────────────────────────────
# Docker: redis://redis:6379
# XAMPP / local: redis://localhost:6379
REDIS_URL=redis://localhost:6379
REDIS_PORT=6379

# ─── Auth ─────────────────────────────────────────────────────────────────────
# Generate with: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
JWT_ACCESS_SECRET=change-me-access-secret-min-32-chars-xxx
JWT_REFRESH_SECRET=change-me-refresh-secret-min-32-chars-xxx
JWT_ACCESS_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=7d
COOKIE_SECRET=change-me-cookie-secret-min-32-chars-xxxx

# ─── File Storage ─────────────────────────────────────────────────────────────
STORAGE_DRIVER=local
STORAGE_LOCAL_PATH=./uploads

# ─── Email ────────────────────────────────────────────────────────────────────
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=noreply@lendora.com.bd
SMTP_PASS=your-app-password
SMTP_FROM="Lendora <noreply@lendora.com.bd>"

# ─── Payment — bKash Tokenized Checkout v1.2 ─────────────────────────────────
# Sandbox: https://tokenized.sandbox.bka.sh/v1.2.0-beta
# Live:    https://tokenized.pay.bka.sh/v1.2.0-beta
BKASH_APP_KEY=
BKASH_APP_SECRET=
BKASH_USERNAME=
BKASH_PASSWORD=
BKASH_BASE_URL=https://tokenized.sandbox.bka.sh/v1.2.0-beta

# ─── Payment — Nagad Merchant API ─────────────────────────────────────────────
# Sandbox: https://sandbox.mynagad.com
# Live:    https://api.mynagad.com
NAGAD_MERCHANT_ID=
NAGAD_MERCHANT_KEY=

# RSA key pair generated by Nagad during merchant onboarding.
# NAGAD_MERCHANT_PRIVATE_KEY: your private key (PEM, base64-encoded, single line)
# NAGAD_PUBLIC_KEY:           Nagad's public key (PEM, provided by Nagad)
NAGAD_MERCHANT_PRIVATE_KEY=
NAGAD_PUBLIC_KEY=
NAGAD_BASE_URL=https://sandbox.mynagad.com

# ─── Rate Limiting ────────────────────────────────────────────────────────────
RATE_LIMIT_WINDOW_MS=60000
RATE_LIMIT_MAX_REQUESTS=100

# ─── Logging ──────────────────────────────────────────────────────────────────
LOG_LEVEL=debug
