{
  "name": "lendora",
  "private": true,
  "version": "1.0.0",
  "description": "Lendora — multi-vendor rental marketplace, Bangladesh.",
  "workspaces": [
    "apps/*",
    "packages/*",
    "frontend"
  ],
  "scripts": {
    "dev":           "turbo run dev",
    "build":         "turbo run build",
    "lint":          "turbo run lint",
    "test":          "turbo run test",
    "typecheck":     "turbo run typecheck",
    "db:generate":   "turbo run db:generate --filter=@lendora/database",
    "db:migrate":    "turbo run db:migrate  --filter=@lendora/database",
    "db:seed":       "turbo run db:seed     --filter=@lendora/database",
    "db:studio":     "turbo run db:studio   --filter=@lendora/database"
  },
  "devDependencies": {
    "turbo":                        "^2.3.3",
    "typescript":                   "^5.7.2",
    "@types/node":                  "^22.10.1",
    "prettier":                     "^3.4.2",
    "prettier-plugin-tailwindcss":  "^0.6.9"
  },
  "packageManager": "pnpm@9.15.0",
  "engines": {
    "node": ">=20.0.0",
    "pnpm": ">=9.0.0"
  }
}
