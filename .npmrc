# Hoist Prisma binaries and client so all workspace packages can resolve them.
# Without this, pnpm strict isolation prevents @prisma/client from being found
# by packages that don't declare it directly (and even some that do, due to how
# Prisma generates its client into node_modules at the root level).
public-hoist-pattern[]=*prisma*
public-hoist-pattern[]=@prisma*

# Hoist sharp (used by the API for image processing) — it has native bindings
# that must be resolvable from the root.
public-hoist-pattern[]=*sharp*
